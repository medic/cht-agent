{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/medic/cht-agent/agent-memory/schema.json",
  "title": "CHT Agent Context File Schema",
  "description": "Schema for validating context files in agent-memory",
  "type": "object",
  "definitions": {
    "CHTDomain": {
      "type": "string",
      "enum": [
        "authentication",
        "contacts",
        "forms-and-reports",
        "tasks-and-targets",
        "messaging",
        "data-sync",
        "configuration",
        "interoperability"
      ],
      "description": "One of the 8 functional domains in CHT"
    },
    "CHTCategory": {
      "type": "string",
      "enum": ["bug", "feature", "improvement"],
      "description": "Issue category"
    },
    "CHTWorkflow": {
      "type": "string",
      "enum": [
        "form-submission",
        "user-registration",
        "contact-creation",
        "task-scheduling",
        "message-processing",
        "data-migration"
      ],
      "description": "Cross-domain workflow processes"
    },
    "CHTService": {
      "type": "string",
      "enum": ["api", "webapp", "sentinel", "admin"],
      "description": "CHT services"
    },
    "frontmatter": {
      "type": "object",
      "description": "YAML frontmatter for markdown context files",
      "required": ["id", "category", "domain", "issueNumber", "issueUrl", "title", "lastUpdated", "summary", "services", "techStack"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cht-core-\\d+$",
          "description": "Unique identifier, format: cht-core-<issue-number>"
        },
        "category": {
          "$ref": "#/definitions/CHTCategory"
        },
        "domain": {
          "$ref": "#/definitions/CHTDomain"
        },
        "subDomain": {
          "type": "string",
          "description": "More specific area within the domain"
        },
        "issueNumber": {
          "type": "integer",
          "minimum": 1,
          "description": "The cht-core GitHub issue number"
        },
        "issueUrl": {
          "type": "string",
          "pattern": "^https://github\\.com/medic/cht-core/issues/\\d+$",
          "description": "Full URL to the cht-core issue"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Brief descriptive title"
        },
        "lastUpdated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date of last update (YYYY-MM-DD)"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "1-2 sentence overview of the issue and resolution"
        },
        "services": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CHTService"
          },
          "minItems": 1,
          "description": "Which CHT services are involved"
        },
        "techStack": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Technologies relevant to the fix"
        }
      }
    },
    "domainToComponentsIndex": {
      "type": "object",
      "description": "Maps domains to their component files",
      "properties": {
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "domains": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "api": {
                "type": "object",
                "properties": {
                  "controllers": { "type": "array", "items": { "type": "string" } },
                  "services": { "type": "array", "items": { "type": "string" } }
                }
              },
              "webapp": {
                "type": "object",
                "properties": {
                  "modules": { "type": "array", "items": { "type": "string" } },
                  "services": { "type": "array", "items": { "type": "string" } }
                }
              },
              "sentinel": {
                "type": "object",
                "properties": {
                  "transitions": { "type": "array", "items": { "type": "string" } }
                }
              },
              "shared_libs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "path": { "type": "string" },
                    "critical": { "type": "boolean" }
                  }
                }
              },
              "tests": {
                "type": "object",
                "properties": {
                  "unit": { "type": "array", "items": { "type": "string" } },
                  "integration": { "type": "array", "items": { "type": "string" } },
                  "e2e": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "errorPatternsIndex": {
      "type": "object",
      "description": "Maps error patterns to locations and solutions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "common_locations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_domains": {
            "type": "array",
            "items": { "$ref": "#/definitions/CHTDomain" }
          },
          "typical_causes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "solutions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "test_scenarios": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
