# Anthropic API Key for Claude models
ANTHROPIC_API_KEY=your_api_key_here

# OpenRouter API key (used when OPENROUTER_API_KEY is set; takes priority over Anthropic)
OPENROUTER_API_KEY=your_openrouter_key_here

# Model for PR triage/filter step (simple 3-class classification)
# Recommended open alternatives: google/gemma-3-4b-it, microsoft/phi-4-mini-instruct
# Default: anthropic/claude-haiku-4-5
TRIAGE_MODEL=google/gemma-3-4b-it

# Model for PR distillation step (structured knowledge extraction)
# Recommended open alternatives: deepseek/deepseek-chat-v3-0324, qwen/qwen2.5-32b-instruct
# Default: anthropic/claude-sonnet-4-5
DISTILL_MODEL=deepseek/deepseek-chat-v3-0324
